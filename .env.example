# --- Service ---
NODE_ENV=production
LOG_LEVEL=info
SERVICE_NAME=autonomous-seo-bot
DB_PATH=./data/seo.db
HTTP_PORT=9100
HTTP_HOST=127.0.0.1
# Comma-separated origins allowed to read /v1/content (CORS). Default loopback only.
ALLOWED_ORIGINS=http://localhost:3000

# --- Site context ---
# Used for the verify worker (does the live page render the new value?)
# and for User-Agent strings sent to Google APIs.
# One URL per locale, comma-separated as locale=url pairs.
SITE_URLS=en=https://example.com,ru=https://example.com
PRIMARY_SITE_URL=https://example.com

# --- Brand voice ---
# Free-form text injected as system context into every LLM prompt. Use it to:
#   - state hard facts about your product (real features, pricing, integrations)
#   - forbid specific phrases or invented features
#   - set tone (terse / formal / playful / etc.)
# Bot will NOT invent features outside this blurb.
BRAND_BLURB="Acme — describe your product in 4-6 lines of plain text. List concrete facts the LLM is allowed to reference. Forbid invented features explicitly."

# Brand-name regex. Queries matching this are skipped during opportunity classification
# (they are usually navigational and don't need SEO improvements).
# Example: "acme|acme inc|acmecorp"
BRAND_TERMS_REGEX=acme

# --- Google APIs (Phase 1) ---
GOOGLE_APPLICATION_CREDENTIALS=./.secrets/google-service-account.json
GA4_PROPERTY_ID=
# Comma-separated list of GSC properties (use sc-domain: prefix for domain properties)
GSC_SITES=sc-domain:example.com

# --- OpenRouter (Phase 2) ---
OPENROUTER_API_KEY=
OPENROUTER_DAILY_BUDGET_USD=1.00
OPENROUTER_MONTHLY_BUDGET_USD=30.00
OPENROUTER_REFERER=https://example.com
OPENROUTER_APP_TITLE=autonomous-seo-bot

# --- Telegram (optional — for daily reports + review prompts) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_THREAD_ID=

# --- Risk gate (Phase 3) ---
AUTO_APPLY_LOW_RISK=true
MAX_AUTO_CHANGES_PER_DAY=20
COOLDOWN_AFTER_REGRESSION_HOURS=24
