# --- Service ---
NODE_ENV=production
LOG_LEVEL=info
DB_PATH=/srv/csboard-seo/data/seo.db
HTTP_PORT=9100
# 0.0.0.0 lets docker bridge containers (csboard-frontend-prod) reach us
# via host gateway. Combined with ufw rules / iptables, no public exposure.
HTTP_HOST=0.0.0.0
# Frontend domains allowed to read (for future CORS hardening; default is localhost-only)
ALLOWED_ORIGINS=http://localhost:3000,https://csboard.com,https://csboard.trade

# --- Google APIs (Phase 1) ---
GOOGLE_APPLICATION_CREDENTIALS=/srv/csboard-seo/.secrets/google-service-account.json
GA4_PROPERTY_ID=337655668
GSC_SITES=sc-domain:csboard.com,sc-domain:csboard.trade

# --- OpenRouter (Phase 2) ---
OPENROUTER_API_KEY=
OPENROUTER_DAILY_BUDGET_USD=1.00
OPENROUTER_MONTHLY_BUDGET_USD=30.00

# --- Telegram (Phase 0d) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_THREAD_ID=
# Optional: dedicated thread for SEO alerts inside CSBoard chat

# --- Risk gate (Phase 3) ---
AUTO_APPLY_LOW_RISK=true
MAX_AUTO_CHANGES_PER_DAY=20
COOLDOWN_AFTER_REGRESSION_HOURS=24
